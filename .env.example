# Qwen Cloud API Configuration
QWEN_API_KEY=your_qwen_cloud_api_key_here
#
# IMPORTANT — pick the endpoint that matches where your API key was created.
# Alibaba Model Studio has two regions with SEPARATE, non-interchangeable keys.
# Using a key against the wrong region returns: 401 Incorrect API key.
#
#   International (most non-China accounts):
#     QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#     DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
#
#   Mainland China (default below):
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Model Selection (use Qwen Cloud model names)
QWEN_CHAT_MODEL=qwen-plus
QWEN_VISION_MODEL=qwen-vl-plus
QWEN_VIDEO_MODEL=wan2.1-t2v-turbo

# Wan 2.1 text-to-video (native DashScope async API)
# Use the -intl host below if your key is an International-region key.
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
WAN_SIZE=720*1280
WAN_POLL_INTERVAL_MS=5000
WAN_POLL_TIMEOUT_MS=300000

# Optional: Alibaba Cloud OSS for video storage
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=reelweaver-output
OSS_ACCESS_KEY_ID=your_access_key
OSS_ACCESS_KEY_SECRET=your_secret_key

# ReelWeaver local UI server
PORT=3000

# Token Budget (total across all stages)
TOKEN_BUDGET_TOTAL=30000
TOKEN_BUDGET_SCRIPTWRITING=8000
TOKEN_BUDGET_STORYBOARDING=6000
TOKEN_BUDGET_VIDEO_GEN=12000
TOKEN_BUDGET_EDITING=4000